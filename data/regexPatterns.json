{
  "core": {
    "replace": [
      {
        "match": "^\\d+\\.?\\d*%?\\s+",
        "replace": ""
      },
      {
        "match": "^>.*<\\n",
        "replace": ""
      },
      {
        "match": "\\n[\\s\\S]*",
        "replace": ""
      },
      {
        "match": "armour",
        "replace": "armor"
      }
    ],
    "validation": ["weapon damage", "armor", "skill tier"]
  },
  "attributes": {
    "cleanPass": [
      { "match": "armour", "replace": "armor" },
      { "match": ",", "replace": "" }
    ],
    "any": [
      { "match": "^any basic$" },
      {
        "match": "^any basic\\s*\\n\\(cant be hsd\\)$",
        "replace": "headshot damage"
      },
      {
        "match": "^any basic\\s*\\n\\(cant be handling\\)$",
        "replace": "weapon handling"
      },
      {
        "match": "^any basic\\s*\\n\\(cant be status\\)$",
        "but": ["status effects"]
      }
    ],
    "mod": ["^mod slot$"],
    "is": [
      "^(.*)\\n(\\d+\\.?\\d*)%?$",
      "^(.*)\\n.* - (\\d+\\.?\\d*)%?$",
      "^(\\d+\\.?\\d*)%?\\s+(.*)$",
      "^(.*)\\n.* - (\\d+)$",
      "^(.*)\\s+(\\d+\\.?\\d*)%?$",
      "^>\\+(\\d+)<\\n(.*)$",
      "^(\\d+)\\+\\s+(.*)$"
    ],
    "oneOf": [
      { "match": "----", "values": {} },
      { "match": "any basic red attribute", "classification": "offensive" },
      { "match": "any basic blue attribute", "classification": "defensive" }
    ]
  },
  "exoticWeapons": {
    "clean": [
      { "match": "magazine: mag of holding", "replace": ""},
      { "match": "[\\s\\u00A0]+", "replace": " " }
    ],
    "is": ["^(.*?):\\s*\\+?(\\d+)%?\\s+(.*)$"]
  },
  "weaponMods": {
    "cleanType": [
      { "match": " rail", "replace": "" },
      { "match": " slot", "replace": "" }
    ],
    "clean": [
      { "match": "pulses targets at which it's aimed", "replace": "" },
      { "match": "illuminates dark areas", "replace": "" }
    ],
    "is": ["^\\+(\\d+)%?\\s+(.*?)\\n[\\s\\S]*$"],
    "mapping": {
      "4\\": ["optics rail", "magazine slot", "muzzle slot", "underbarrel"],
      "4": ["optics", "magazine slot", "muzzle slot", "underbarrel"],
      "(Empty/NaN)": [],
      "3!": ["optics", "magazine slot", "underbarrel"],
      "3!\\": ["optics rail", "magazine slot", "underbarrel"],
      "3#": ["optics", "magazine slot", "muzzle slot"],
      "0": [],
      "2$!": ["optics", "underbarrel"],
      "4/": ["optics", "magazine slot", "muzzle slot", "underbarrel"],
      "2$#": ["optics", "muzzle slot"],
      "3&": ["magazine slot", "muzzle slot", "underbarrel"],
      "2!#": ["optics", "magazine slot"],
      "1#&!": ["muzzle slot"],
      "1$#!": ["optics"],
      "1#!&": ["muzzle slot"],
      "3": ["optics", "magazine slot", "muzzle slot"],
      "4*": ["optics", "magazine slot", "muzzle slot", "underbarrel"],
      "2&#": ["magazine slot", "muzzle slot"],
      "2#&": ["magazine slot", "muzzle slot"],
      "2&!": ["magazine slot", "underbarrel"],
      "1&!#": ["magazine slot"],
      "3!*": ["optics", "magazine slot", "underbarrel"],
      "1!#$": ["optics"],
      "2!&": ["magazine slot", "underbarrel"]
    }
  }
}
